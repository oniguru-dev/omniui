{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": ["bun", "bun-types"],
    "paths": {
      "#/*": ["./*"],
      "@/*": ["./src/*", "./app/*", "./public/*"]
    },
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src", "app", "public"],
  "exclude": ["node_modules", "dist"]
}
