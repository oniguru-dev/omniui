{
  "name": "@omnixui/omniui",
  "version": "1.1.11-hotfix2",
  "description": "Lightweight UI framework for Bun with file routing, server components, and UnoCSS",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "omniui": "src/cli.ts"
  },
  "main": "src/index.ts",
  "types": "types.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./plugin": "./src/plugin.ts"
  },
  "files": [
    "src/",
    "public/",
    "template/",
    "types.d.ts",
    "bunfig.toml",
    "README.md"
  ],
  "scripts": {
    "dev": "bun --watch src/server",
    "start": "bun src/server.ts",
    "build": "bun run src/scripts/build.script.ts"
  },
  "dependencies": {
    "@elysiajs/static": "^1.4.10",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "elysia": "^1.4.29",
    "elysia-rate-limit": "^4.6.2",
    "fflate": "^0.8.3",
    "lightningcss": "^1.32.0",
    "lottie-web": "^5.13.0",
    "preact": "^10.29.2",
    "unocss": "^66.7.2",
    "wouter-preact": "^3.10.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": [
    "bun",
    "framework",
    "elysia",
    "preact",
    "unocss",
    "ssr",
    "routing"
  ],
  "license": "MIT",
  "resolutions": {
    "oxc-parser": ">=0.131.0",
    "@emnapi/core": ">=1.10.0"
  }
}
